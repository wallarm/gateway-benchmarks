# gateways/nginx/p12-full-pipeline/.env
#
# p11 combines JWT + static RL + req-headers + req-body + resp-headers
# + resp-body in one chain. JWT and body rewrites need OpenResty;
# `more_clear_headers "Server"` needs ngx_headers_more (also bundled
# with OpenResty). Same pin as p02/p08/p09/p10.
GATEWAY_IMAGE=openresty/openresty:1.27.1.2-alpine@sha256:761047d688bb91fe4eb42c42a05c794c54f274ee769ad54802b2c06247e8c38c
