# gateways/nginx/p03-jwks-rs256-basic/.env
#
# The `p03-jwks-rs256-basic` profile runs on OpenResty because
# mainline nginx has no Lua and no directive-level JWT/JWKS primitive.
# OpenResty ships:
#
#   * `ngx_http_lua_module` — `access_by_lua_block`, `init_by_lua_block`
#   * `lua-cjson` — JWT / JWKS JSON parsing
#   * LuaJIT FFI + OpenSSL 3.5.5 under `/usr/local/openresty/openssl3/lib/`
#     — consumed directly by `_shared/lualib/jwt_rs256_verify.lua`
#     via `ffi.load("/usr/local/openresty/openssl3/lib/libcrypto.so")`.
#     Same image OpenResty itself was linked against, so there is no
#     ABI-mismatch risk.
#
# Same image as p02-jwt / p08 / p09 / p10 / p11 by design — one
# OpenResty pin across every nginx cell that needs Lua or
# ngx_headers_more. Pinned by digest for reproducibility:
#   docker pull openresty/openresty:1.27.1.2-alpine
#   docker image inspect openresty/openresty:1.27.1.2-alpine \
#     --format '{{index .RepoDigests 0}}'
GATEWAY_IMAGE=openresty/openresty:1.27.1.2-alpine@sha256:761047d688bb91fe4eb42c42a05c794c54f274ee769ad54802b2c06247e8c38c
