# gateways/nginx/p09-resp-headers/.env
#
# p08 needs to *remove* the Server response header. Mainline nginx
# cannot do this — `proxy_hide_header Server;` only strips the
# upstream's Server; nginx then adds its own `Server: nginx/X.Y.Z`
# on the way out, and mainline has no directive to suppress that.
# The canonical idiom is `more_clear_headers "Server";` from the
# third-party `ngx_headers_more` module, which OpenResty bundles.
#
# We therefore swap the image to OpenResty for this one profile.
# Binary path, user, and config layout remain compatible with our
# `command: ["nginx", ...]` line (the `nginx` symlink is on PATH in
# the OpenResty image).
#
# Pinned by digest for reproducibility (compare with how mainline's
# digest is pinned in docker-compose.yaml):
#   docker pull openresty/openresty:1.27.1.2-alpine
#   docker image inspect openresty/openresty:1.27.1.2-alpine \
#     --format '{{index .RepoDigests 0}}'
#
# `scripts/parity-gateway.sh` sources this file before `docker compose
# up` so the GATEWAY_IMAGE variable lands in the compose environment.
GATEWAY_IMAGE=openresty/openresty:1.27.1.2-alpine@sha256:761047d688bb91fe4eb42c42a05c794c54f274ee769ad54802b2c06247e8c38c
