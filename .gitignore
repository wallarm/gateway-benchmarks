# ---- Local scratch (never committed) ----
.notes/
.omx/

# ---- Go ----
orchestrator/bin/
orchestrator/vendor/
*.test
*.out

# ---- Reports ----
# Per-run artefacts stay local (a single run weighs multiple GB of k6
# NDJSON + docker-stats CSVs). Aggregated / combined reports DO ship in
# git — they are the user-facing deliverable reviewers expect next to the
# source. Raw per-cell data is published as GitHub Release assets, not
# in-tree.
reports/*
!reports/README.md
# Re-include any directory named `combined-*` as a whole — git needs the
# directory un-ignored BEFORE its contents can be considered. We list the
# bare directory name (no trailing slash) because `reports/*` matches both
# files and dirs, and git only re-scans the directory when the exception
# covers the same form as the original match.
!reports/combined-*
# Inside a re-included directory, ignore everything that is NOT one of the
# three reviewer-facing artefacts, so we do not accidentally ship the
# per-cell raw/ sub-trees if someone drops them under combined-*.
reports/combined-*/raw
reports/combined-*/raw/**
reports/combined-*/*.log
reports/combined-*/*.tmp
reports/combined-*/*.json

# ---- Terraform / OpenTofu ----
infra/aws/.terraform/
infra/aws/.terraform.lock.hcl
infra/aws/terraform.tfstate
infra/aws/terraform.tfstate.backup
infra/aws/terraform.tfvars
infra/aws/*.auto.tfvars
infra/aws/crash.log

# ---- Docker ----
*.env
docker-compose.override.yaml
# Exception: per-profile .env files under gateways/ are NOT secrets —
# they carry pinned image digests that override the default gateway
# image for a specific profile (e.g. openresty in place of mainline
# nginx for p09-resp-headers). These are read by
# scripts/parity-gateway.sh via `docker compose --env-file` and must
# be committed so the benchmark is reproducible.
!gateways/**/.env

# ---- Editor / OS ----
.DS_Store
.vscode/
.idea/
*.swp
*~

# ---- Temporary files ----
/tmp/
*.tmp
*.log

# ---- Python ----
__pycache__/
*.pyc
