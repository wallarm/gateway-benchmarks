# gateways/nginx/p02-jwt/.env
#
# p02-jwt runs on OpenResty because mainline nginx has no Lua, and
# stock mainline has no JWT directive. OpenResty ships the
# ngx_http_lua_module + resty.sha256 + cjson.safe primitives we need
# to implement HS256 verification inline (see
# _shared/lualib/jwt_hs256.lua for the ~60-line pure-Lua HMAC-SHA-256
# + JWT decode).
#
# Same image as p09-resp-headers by design — one OpenResty pin
# across every nginx cell that needs Lua or ngx_headers_more.
# Pinned by digest for reproducibility:
#   docker pull openresty/openresty:1.27.1.2-alpine
#   docker image inspect openresty/openresty:1.27.1.2-alpine \
#     --format '{{index .RepoDigests 0}}'
GATEWAY_IMAGE=openresty/openresty:1.27.1.2-alpine@sha256:761047d688bb91fe4eb42c42a05c794c54f274ee769ad54802b2c06247e8c38c
