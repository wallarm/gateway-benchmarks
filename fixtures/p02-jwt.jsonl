{"name":"no Authorization header -> 401","request":{"method":"GET","path":"/anything"},"expect":{"status":401}}
{"name":"garbage bearer token -> 401","request":{"method":"GET","path":"/anything","headers":{"Authorization":"Bearer not.a.jwt"}},"expect":{"status":401}}
{"name":"malformed Authorization scheme -> 401","request":{"method":"GET","path":"/anything","headers":{"Authorization":"Basic Zm9vOmJhcg=="}},"expect":{"status":401}}
{"name":"valid HS256 token -> 200","request":{"method":"GET","path":"/anything","headers":{"Authorization":"Bearer ${JWT_VALID}"}},"expect":{"status":200}}
{"name":"expired HS256 token -> 401","request":{"method":"GET","path":"/anything","headers":{"Authorization":"Bearer ${JWT_EXPIRED}"}},"expect":{"status":401}}
{"name":"wrong-secret HS256 token -> 401","request":{"method":"GET","path":"/anything","headers":{"Authorization":"Bearer ${JWT_WRONG}"}},"expect":{"status":401}}
