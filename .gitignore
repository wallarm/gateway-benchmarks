# ---- Local scratch (never committed) ----
.notes/
.omx/
external/

# ---- Go ----
orchestrator/bin/
orchestrator/vendor/
*.test
*.out

# ---- Reports ----
# `reports/` is strictly local output — per-run artefacts easily weigh
# tens of GB. NOTHING inside it is tracked: no README, no aggregates.
# That way users are free to replace the directory with a symlink to
# external storage (e.g. /Volumes/…/reports) without git ever trying
# to "restore" a tracked path and clobbering the symlink on checkout /
# reset / clean. Reviewer-facing aggregated reports ship as GitHub
# Release assets, documented in docs/REPORT.md.
#
# The pattern `reports` (no trailing slash) intentionally matches BOTH
# a plain directory AND a symlink named `reports`. If we used
# `reports/`, git would leave the symlink showing up as untracked and
# `git clean -f` could remove it.
reports
reports/**

# ---- Terraform / OpenTofu ----
# .terraform/ is the local plugin/module cache — never tracked.
infra/aws/.terraform/
# .terraform.lock.hcl IS tracked — it pins exact provider versions
# so reviewers reproducing the AWS deploy get bit-identical
# provider behaviour. Standard HashiCorp guidance.
infra/aws/terraform.tfstate
infra/aws/terraform.tfstate.backup
infra/aws/terraform.tfstate.lock.info
# tfvars + tfvars.json hold operator-specific values (SSH key name,
# allowed IPs, sometimes secrets) — keep them out, ship the
# .tfvars.example template instead.
infra/aws/terraform.tfvars
infra/aws/*.auto.tfvars
infra/aws/crash.log

# ---- Docker ----
*.env
docker-compose.override.yaml
# Exception: per-profile .env files under gateways/ are NOT secrets —
# they carry pinned image digests that override the default gateway
# image for a specific profile (e.g. openresty in place of mainline
# nginx for p09-resp-headers). These are read by
# scripts/parity-gateway.sh via `docker compose --env-file` and must
# be committed so the benchmark is reproducible.
!gateways/**/.env

# ---- Editor / OS ----
.DS_Store
.vscode/
.idea/
*.swp
*~

# ---- Temporary files ----
/tmp/
*.tmp
*.log

# ---- Python ----
__pycache__/
*.pyc
