# infra/local/.env.example
#
# Copy to `infra/local/.env` and tweak before invoking `make perf-local-up`.
# Compose v2 reads the .env file in the same directory as the compose
# file by default, so no `--env-file` flag is needed.

# ---------------------------------------------------------------------------
# Gateway image + profile  ("which gateway and which policy?")
# ---------------------------------------------------------------------------
# Default: nginx mainline + p01-vanilla. Reviewers can `up` and
# immediately get a working pure-proxy gateway with a TLS listener
# on :9443. Switch to OpenResty + p12-full-pipeline for the
# end-to-end pipeline smoke (s14-full-pipeline-https):
#
#   GATEWAY_IMAGE=openresty/openresty:1.25.3.2-2-alpine
#   GATEWAY_PROFILE=p12-full-pipeline
GATEWAY_IMAGE=nginx:1.27.3-alpine@sha256:814a8e88df978ade80e584cc5b333144b9372a8e3c98872d07137dbf3b44d0e4
GATEWAY_PROFILE=p01-vanilla

# Override the gateway entrypoint command for non-nginx images. Default
# matches gateways/nginx/docker-compose.yaml so the existing per-profile
# nginx.conf files apply unchanged.
# GATEWAY_COMMAND=nginx -c /etc/nginx/nginx.conf -g "daemon off;"

# Host-port bindings. Defaults match every other gateway compose so
# k6 harness scripts on the host can reuse `BENCH_TARGET_URL=http://localhost:9080`.
GATEWAY_HOST_PORT_HTTP=9080
GATEWAY_HOST_PORT_HTTPS=9443

# ---------------------------------------------------------------------------
# Resource pinning (cpus + memory + ulimits)
# ---------------------------------------------------------------------------
# Default budget: 7 CPU / 3.5G total. Comfortably fits a 2021+
# MacBook Pro (10-core M1 / 16G) or a c6i.2xlarge with 1G headroom.
# Reduce on smaller laptops; raise on dedicated bench hosts.
LOADGEN_CPUS=2.0
LOADGEN_MEM=1g

GATEWAY_CPUS=4.0
GATEWAY_MEM=2g

BACKEND_CPUS=1.0
BACKEND_MEM=512m

# ---------------------------------------------------------------------------
# Output directory  (relative to infra/local/, expanded by compose)
# ---------------------------------------------------------------------------
# Where the loadgen container writes k6-summary.json + stream files.
# Default lands them under reports/local-smoke/ on the host.
LOCAL_OUTPUT_DIR=../../reports/local-smoke

# ---------------------------------------------------------------------------
# Backend image  (override only when iterating on the backend itself)
# ---------------------------------------------------------------------------
BACKEND_IMAGE=gateway-benchmarks/backend:v2.22.1

# ---------------------------------------------------------------------------
# k6 image  (matches scripts/load-gateway.sh K6_IMAGE pin)
# ---------------------------------------------------------------------------
K6_IMAGE=grafana/k6:1.7.1@sha256:4fd3a694926b064d3491d9b02b01cde886583c4931f1223816e3d9a7bdfa7e0f
