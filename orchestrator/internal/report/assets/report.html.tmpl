<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ .Title | esc }}</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<style>{{ .CSS | cssSafe }}</style>
</head>
<body>

<header class="hero">
  <div class="wrap">
    <div class="hero-titles">
      <h1>{{ .Title | esc }}</h1>
      <p class="meta">
        Generated {{ .GeneratedAt | esc }}
        &nbsp;&bull;&nbsp; {{ .EnvLine | esc }}
        {{- with .Manifest }}{{- if .K6.Image }}
        &nbsp;&bull;&nbsp; <span title="{{ .K6.Digest | esc }}">k6 {{ k6Version .K6.Image | esc }}</span>
        {{- end }}{{- end }}
      </p>
    </div>
    {{- if .LogoDataURI }}
    <div class="hero-logo-wrap">
      <img class="hero-logo" src="{{ .LogoDataURI | urlSafe }}" alt="Report logo">
    </div>
    {{- end }}
  </div>
</header>

<div class="wrap">

{{- if .HowToRead }}
<details class="note-card">
  <summary><strong>How to read this report</strong></summary>
  <div class="note-card-body">{{ .HowToRead | safe }}</div>
  {{- with .HeroNote }}<br><br>{{ . | safe }}{{ end }}
</details>
{{- end }}

<h2 class="section-title">Executive Summary</h2>
<div class="card" style="margin-bottom:1rem">
  <table class="ranking-table sortable">
    <thead><tr>
      <th style="text-align:center" data-sort="numeric" title="Position in the ranking by Avg RPS (descending). Click any header to re-sort by that column; click again to reverse direction.">Rank</th>
      <th data-sort="string" title="Gateway implementation under test. Click to sort alphabetically.">Gateway</th>
      <th data-sort="string" title="Implementation language and version pin. Click to sort alphabetically.">Stack</th>
      <th style="text-align:right" data-sort="numeric" title="Mean RPS across every PASS cell this gateway produced. Higher is better. The Executive Summary defaults to sorting by this column.">Avg RPS</th>
      <th data-sort="numeric" title="Worst per-cell ratio of unexpected errors (policy_5xx_unexpected + policy_4xx_unexpected) divided by total classified responses. Expected policy responses (401/429) are NOT counted. Higher = unhealthier under load.">Max errors</th>
      <th data-sort="coverage" title="Number of cells that finished with verdict=PASS / total cells attempted for this gateway. Format: passed/total. Excluded and failed cells are NOT in the numerator.">Coverage</th>
      {{- if $.HasResourceData }}
      <th data-sort="numeric" title="Peak Resident Set Size — the highest amount of physical RAM the gateway process held during the run, sampled once per second from the Docker engine stats endpoint. Lower means a smaller production memory footprint.">Peak RSS</th>
      <th data-sort="numeric" title="Steady-state Resident Set Size — mean RAM held by the gateway process during the last 30 seconds of the cell (warm path, JIT/cache populated). Lower is better.">Steady RSS</th>
      {{- end }}
    </tr></thead>
    <tbody>
    {{- range $i, $row := .Summary }}
      <tr>
        <td class="rank-cell">{{ rank $i }}</td>
        <td><span class="badge" style="background:{{ color $row.Gateway | esc }}">{{ $row.Gateway | esc }}</span></td>
        <td class="meta-cell">{{ index $row.Stack 0 | esc }} · {{ index $row.Stack 1 | esc }}</td>
        <td class="num">{{ fmtFloat $row.AvgRPS 1 }}</td>
        <td class="{{ if gt $row.MaxErrPct 0.5 }}error-cell{{ end }}">{{ fmtFloat $row.MaxErrPct 1 }}%</td>
        <td>{{ $row.Coverage | esc }}</td>
        {{- if $.HasResourceData }}
        <td class="meta-cell">{{ fmtMaybeMB $row.PeakRSSMB }}</td>
        <td class="meta-cell">{{ fmtMaybeMB $row.SteadyRSSMB }}</td>
        {{- end }}
      </tr>
    {{- end }}
    </tbody>
  </table>
</div>

{{- if gt (len .MemoryChips) 0 }}
<h2 class="section-title">Memory Footprint (peak RSS)</h2>
<div class="card"><div class="mem-grid">
  {{- range .MemoryChips }}
  <div class="mem-chip">
    <div class="num-big" style="color:{{ .Color | esc }}">~{{ fmtFloat .PeakRSSMB 0 }} MB</div>
    <div class="label">{{ .Gateway | esc }}</div>
  </div>
  {{- end }}
</div></div>
{{- end }}

{{- if gt (len .RadarLabels) 0 }}
<h2 class="section-title">Overall Profile</h2>
<div class="card"><div class="radar-wrap"><canvas id="radarChart"></canvas></div></div>
{{- end }}

<h2 class="section-title">Policy Details</h2>
<div class="tabs">
{{- range $i, $tab := .Tabs }}
  <button class="tab-btn{{ if eq $i 0 }} active{{ end }}" data-tab="tab-{{ $tab.Policy | esc }}">{{ $tab.Meta.Label | esc }}</button>
{{- end }}
</div>

{{- range $i, $tab := .Tabs }}
<div class="tab-panel{{ if eq $i 0 }} active{{ end }}" id="tab-{{ $tab.Policy | esc }}">
  <div class="scenario-header">
    <h3>{{ $tab.Meta.Label | esc }}</h3>
    <span class="parity-line">{{ $tab.ParityLine | esc }}</span>
    {{- if $tab.HasUnstable }}
    <span class="unstable-tag" title="At least one cell shows multi-rep RPS spread > 5%">unstable cells</span>
    {{- end }}
  </div>

  <div class="policy-meta">
    <div><strong>Tested:</strong> {{ $tab.Meta.Tested | esc }}</div>
    <div><strong>Profile:</strong> {{ $tab.Meta.Profile | esc }}</div>
    <div><strong>Expected signal:</strong> {{ $tab.Meta.Signal | esc }}</div>
  </div>

  {{- range $tab.Loads }}
  <div class="load-section">
    <div class="load-header">
      <h4>{{ .Meta.Label | esc }}</h4>
      <span class="load-shape">{{ .Meta.Shape | esc }}</span>
    </div>
    <p class="load-purpose">{{ .Meta.Purpose }}</p>

    {{- if gt (len .Cells) 0 }}
    <div class="chart-row">
      <div class="chart-box"><canvas id="chart-rps-{{ $tab.Policy | esc }}-{{ .Load | esc }}"></canvas></div>
      <div class="chart-box"><canvas id="chart-lat-{{ $tab.Policy | esc }}-{{ .Load | esc }}"></canvas></div>
    </div>
    {{- end }}

    <table class="sortable">
      <thead><tr>
        <th data-sort="string" title="Gateway implementation under test. Click any header to sort the table by that column; click again to reverse direction.">Gateway</th>
        <th data-sort="numeric" title="Requests per second observed by k6 (closed-loop iteration cadence — apples-to-apples with api7/apisix-benchmark, not absolute-arrival rate). Higher is better. Default sort.">RPS</th>
        <th data-sort="numeric" title="Median request duration (50th percentile) in milliseconds, measured by k6 client-side. Lower is better. N/A means the timing instrumentation returned all-zeros for this cell (rare — usually a connection-refused or measurement bug).">p50 (ms)</th>
        <th data-sort="numeric" title="95th percentile request duration in milliseconds. The 'tail' latency metric — captures the worst 5% of requests. Lower is better.">p95 (ms)</th>
        <th data-sort="numeric" title="Count of unexpected errors: policy_5xx_unexpected + policy_4xx_unexpected. Expected policy responses (401 on bad JWT, 429 on rate-limit) are NOT counted here — those are recorded under policy_4xx_expected and confirm the policy works as designed.">Errors</th>
        <th data-sort="numeric" title="Total requests issued by k6 during this cell. Higher correlates with higher RPS and longer duration. Use the RPS column for cross-cell comparison since durations differ between load profiles.">Requests</th>
        <th data-sort="rss" title="Container Resident Set Size — physical RAM held by the gateway process. Format: peak / steady-state. Peak is the highest 1-second sample during the run; steady is the mean over the last 30 seconds (warm path, after JIT and connection pools settle). Sorted by peak. '—' means docker-stats data was unavailable for this cell.">RSS (peak / steady)</th>
        <th data-sort="rss" title="Docker CPU usage as &quot;peak / steady&quot;. 100% is approximately one fully used vCPU; on multi-core instances values above 100% mean multiple cores are engaged simultaneously. The bottleneck column uses max(peak, steady) against the available vCPU cap (cpu_online×100), so a peak well above the steady column is what trips the &quot;cpu&quot; verdict — the steady value alone can look modest while peak still saturates. Sort key is peak.">CPU % (peak/steady)</th>
        <th data-sort="string" title="Likely resource bottleneck inferred from per-second docker-stats samples. Decided by the FIRST threshold crossed (priority order):&#10;• cpu — max(steady, peak) CPU ≥85% of available vCPU capacity (e.g. ≥6.8 of 8 vCPUs on c7i.2xlarge)&#10;• ram — peak memory utilisation ≥85% of the container's memory limit&#10;• disk — peak read OR write throughput ≥80 MB/s&#10;• network — peak rx OR tx throughput ≥100 MB/s (the gateway is saturating the NIC; faster CPU won't help)&#10;• (blank/—) — no signal crossed its threshold OR docker-stats data was unavailable.&#10;Hover the value below for the raw four-channel measurements.">Bottleneck</th>
      </tr></thead>
      <tbody>
      {{- $ref := .LatWinner }}
      {{- $rpsW := .RPSWinner }}
      {{- range .Cells }}
        <tr class="{{ if and $rpsW (eq .Gateway $rpsW.Gateway) }}winner-row{{ end }}{{ if .Unstable }} unstable-row{{ end }}">
          <td>
            <span class="badge" style="background:{{ color .Gateway | esc }}">{{ .Gateway | esc }}</span>
            {{- if and $rpsW (eq .Gateway $rpsW.Gateway) }} 🏆{{ end }}
            {{- if and $ref (eq .Gateway $ref.Gateway) }} ⏱️{{ end }}
            {{- if .Unstable }} <span class="unstable-tag" title="multi-rep RPS spread > 5%">unstable</span>{{ end }}
          </td>
          <td class="num">{{ fmtFloat .HTTPReqRate 1 }}</td>
          <td class="num">{{ if .TimingBroken }}<span class="meta-cell" title="k6 timing instrumentation returned zeros">N/A ⚠️</span>{{ else }}{{ fmtFloat .HTTPReqDurationP50 3 }}{{ end }}</td>
          <td class="num">{{ if .TimingBroken }}<span class="meta-cell" title="k6 timing instrumentation returned zeros">N/A ⚠️</span>{{ else }}{{ fmtFloat .HTTPReqDurationP95 3 }}{{ end }}</td>
          <td class="num {{ if gt (unexpectedErrors .) 0 }}error-cell{{ end }}">{{ fmtInt (unexpectedErrors .) }}</td>
          <td class="num">{{ fmtInt .HTTPReqs }}</td>
          <td class="num meta-cell" title="peak / steady">{{ fmtRSSPair .MemRSSPeakBytes .MemRSSSteadyBytes }}</td>
          <td class="num meta-cell" title="peak / steady — see column header">{{ fmtCPUPair .CPUPctPeak .CPUPctSteady }}</td>
          <td>{{ if showBottleneck .ResourceBottleneck }}<span class="bottleneck bottleneck-{{ bottleneckClass .ResourceBottleneck }}" title="{{ .ResourceBottleneckDetail | esc }}">{{ .ResourceBottleneck | esc }}</span>{{ else }}<span class="meta-cell" title="No clear CPU/RAM/disk/network saturation detected, or resource data is unavailable.">—</span>{{ end }}</td>
        </tr>
      {{- end }}
      {{- range .Excluded }}
        <tr class="excluded-row">
          <td><span class="badge" style="background:{{ color .Gateway | esc }}">{{ .Gateway | esc }}</span></td>
          <td colspan="8" class="excluded-cell">FEATURE-MISSING{{ if .ParityStatus }} · parity {{ .ParityStatus | esc }}{{ else }} (see docs/POLICIES.md for the gateway's deviation table){{ end }}</td>
        </tr>
      {{- end }}
      {{- range .Failed }}
        <tr class="failed-row">
          <td><span class="badge" style="background:{{ color .Gateway | esc }}">{{ .Gateway | esc }}</span></td>
          <td colspan="8" class="failed-cell">{{ .Verdict | esc }}{{ if .ParityStatus }} · parity {{ .ParityStatus | esc }}{{ else }} (see raw logs for this cell){{ end }}</td>
        </tr>
      {{- end }}
      </tbody>
    </table>
  </div>
  {{- end }}
</div>
{{- end }}

<footer>
  <div>
    {{ .Footer.PassCount }} PASS
    · {{ .Footer.ExcludedCount }} EXCLUDED
    · {{ .Footer.FailCount }} FAIL
    {{- if gt .Footer.OtherCount 0 }} · {{ .Footer.OtherCount }} OTHER{{ end }}
    across {{ len .Footer.RunIDs }} run(s).
  </div>
  {{- with .Manifest }}
  <div class="meta-cell">run_id: {{ .RunID | esc }}</div>
  {{- end }}
</footer>

</div>

<script>{{ .ScriptJS | jsSafe }}</script>
<script>
(function () {
  const POLICIES = {{ .PoliciesJSON | jsSafe }};
  const CHART_DATA = {{ .ChartDataJSON | jsSafe }};
  const RADAR_LABELS = {{ .RadarLabelsJSON | jsSafe }};
  const RADAR_DATASETS = {{ .RadarSeriesJSON | jsSafe }};

  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      const tab = document.getElementById(btn.dataset.tab);
      if (tab) tab.classList.add('active');
      // Chart.js needs a tick to size to a freshly-visible canvas.
      window.dispatchEvent(new Event('resize'));
    });
  });

  Chart.defaults.font.family = "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif";
  Chart.defaults.font.size = 12;
  Chart.defaults.plugins.legend.display = false;

  POLICIES.forEach(policy => {
    const byLoad = CHART_DATA[policy] || {};
    Object.keys(byLoad).forEach(load => {
      const d = byLoad[load];
      if (!d) return;

      const rpsCanvas = document.getElementById('chart-rps-' + policy + '-' + load);
      if (rpsCanvas) {
        new Chart(rpsCanvas, {
          type: 'bar',
          data: { labels: d.labels, datasets: [{ data: d.rps, backgroundColor: d.colors, borderRadius: 4 }] },
          options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              title: { display: true, text: 'Requests/sec (higher is better)', font: { size: 13, weight: '600' }, padding: { bottom: 12 } }
            },
            scales: {
              x: { beginAtZero: true, grid: { color: '#f0f1f3' } },
              y: { grid: { display: false }, ticks: { font: { weight: '600' } } }
            }
          }
        });
      }

      const latCanvas = document.getElementById('chart-lat-' + policy + '-' + load);
      if (latCanvas) {
        new Chart(latCanvas, {
          type: 'bar',
          data: {
            labels: d.labels,
            datasets: [
              { label: 'p50', data: d.p50, backgroundColor: '#60a5fa', borderRadius: 4 },
              { label: 'p95', data: d.p95, backgroundColor: '#f87171', borderRadius: 4 }
            ]
          },
          options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              title: { display: true, text: 'Latency ms (lower is better)', font: { size: 13, weight: '600' }, padding: { bottom: 12 } },
              legend: { display: true, position: 'bottom', labels: { boxWidth: 12 } }
            },
            scales: {
              x: { beginAtZero: true, grid: { color: '#f0f1f3' } },
              y: { grid: { display: false }, ticks: { font: { weight: '600' } } }
            }
          }
        });
      }
    });
  });

  if (RADAR_DATASETS && RADAR_DATASETS.length > 0) {
    const radar = document.getElementById('radarChart');
    if (radar) {
      new Chart(radar, {
        type: 'radar',
        data: {
          labels: RADAR_LABELS,
          datasets: RADAR_DATASETS.map(ds => Object.assign({}, ds, { borderWidth: 2, pointRadius: 3, fill: true }))
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: true, position: 'bottom', labels: { boxWidth: 12, padding: 16 } },
            title: { display: true, text: 'Relative RPS by policy (% of best)', font: { size: 14, weight: '600' }, padding: { bottom: 8 } }
          },
          scales: {
            r: {
              beginAtZero: true, max: 100,
              ticks: { stepSize: 25, font: { size: 10 }, backdropColor: 'transparent' },
              grid: { color: '#e5e7eb' },
              pointLabels: { font: { size: 11, weight: '500' } }
            }
          }
        }
      });
    }
  }
})();
</script>
</body>
</html>
