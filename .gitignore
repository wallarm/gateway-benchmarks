# ---- Local scratch (never committed) ----
.notes/
.omx/

# ---- Go ----
orchestrator/bin/
orchestrator/vendor/
*.test
*.out

# ---- Reports ----
# Actual runs stay local; only the directory README ships in git.
# (We publish aggregated reports as GitHub Release assets, not in-tree.)
reports/*
!reports/README.md

# ---- Terraform / OpenTofu ----
infra/aws/.terraform/
infra/aws/.terraform.lock.hcl
infra/aws/terraform.tfstate
infra/aws/terraform.tfstate.backup
infra/aws/terraform.tfvars
infra/aws/*.auto.tfvars
infra/aws/crash.log

# ---- Docker ----
*.env
docker-compose.override.yaml
# Exception: per-profile .env files under gateways/ are NOT secrets —
# they carry pinned image digests that override the default gateway
# image for a specific profile (e.g. openresty in place of mainline
# nginx for p09-resp-headers). These are read by
# scripts/parity-gateway.sh via `docker compose --env-file` and must
# be committed so the benchmark is reproducible.
!gateways/**/.env

# ---- Editor / OS ----
.DS_Store
.vscode/
.idea/
*.swp
*~

# ---- Temporary files ----
/tmp/
*.tmp
*.log
